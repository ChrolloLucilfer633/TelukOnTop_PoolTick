datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Ticket {
  id    Int    @id @default(autoincrement())
  name  String
  price Int

  transactions Transaction[]
}

model Transaction {
  id       Int    @id @default(autoincrement())
  ticketId Int
  name     String   // (nama pembeli)
  price    Int

  ticket   Ticket @relation(fields: [ticketId], references: [id])
}